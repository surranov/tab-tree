{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "mocha"],
    "outDir": "out/test/integration",
    "rootDir": "test/integration",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  },
  "include": ["test/integration/**/*.ts"],
  "exclude": ["node_modules"]
}
